{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphamintx.dev/contracts/proposal.schema.json",
  "title": "TradeProposal",
  "description": "TradeProposal v1. The single interface from agent-plane (Python) to control-plane (Go). Normative prose: docs/specs/proposal-contract.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "strategy_id",
    "agent_trace_id",
    "created_at",
    "symbol",
    "action",
    "size_quote",
    "entry",
    "time_in_force",
    "confidence",
    "reasoning",
    "analyst_summaries",
    "debate_summary",
    "model_costs"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "proposal_id": { "$ref": "#/$defs/uuid" },
    "strategy_id": { "$ref": "#/$defs/uuid" },
    "agent_trace_id": { "$ref": "#/$defs/uuid" },
    "created_at": { "$ref": "#/$defs/utc_timestamp" },
    "symbol": { "$ref": "#/$defs/symbol" },
    "action": { "enum": ["open_long", "open_short", "close", "hold"] },
    "size_quote": {
      "$ref": "#/$defs/decimal",
      "description": "Requested notional in quote currency. For close: \"0\" = full close, >0 = partial close in quote units. For hold: \"0\"."
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["market", "limit"] },
        "limit_price": { "$ref": "#/$defs/decimal" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "limit" } }, "required": ["type"] },
          "then": { "required": ["limit_price"] },
          "else": { "not": { "required": ["limit_price"] } }
        }
      ]
    },
    "stop_loss": { "$ref": "#/$defs/decimal" },
    "take_profit": { "$ref": "#/$defs/decimal" },
    "time_in_force": { "enum": ["gtc", "ioc"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reasoning": { "type": "string", "maxLength": 8000 },
    "analyst_summaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["market", "news", "fundamental"],
      "properties": {
        "market": { "$ref": "#/$defs/analyst_summary" },
        "news": { "$ref": "#/$defs/analyst_summary" },
        "fundamental": { "$ref": "#/$defs/analyst_summary" }
      }
    },
    "debate_summary": { "type": "string", "maxLength": 4000 },
    "model_costs": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/model_cost" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "enum": ["open_long", "open_short"] } }, "required": ["action"] },
      "then": { "required": ["stop_loss"] },
      "else": {
        "allOf": [
          { "not": { "required": ["stop_loss"] } },
          { "not": { "required": ["take_profit"] } }
        ]
      }
    }
  ],
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "decimal": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$",
      "maxLength": 34
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,15}/[A-Z0-9]{2,10}$"
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$",
      "maxLength": 35
    },
    "analyst_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal", "confidence", "summary"],
      "properties": {
        "signal": { "enum": ["bullish", "bearish", "neutral"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "summary": { "type": "string", "maxLength": 2000 }
      }
    },
    "model_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "model", "input_tokens", "output_tokens", "cost_usd"],
      "properties": {
        "node": { "type": "string", "maxLength": 64 },
        "model": { "type": "string", "maxLength": 64 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_usd": { "$ref": "#/$defs/decimal" }
      }
    }
  }
}
